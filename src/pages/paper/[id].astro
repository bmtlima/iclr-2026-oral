---
import Base from "../../layouts/Base.astro";
import AbstractBlock from "../../components/AbstractBlock.astro";
import AutoGeneratedBlock from "../../components/AutoGeneratedBlock.astro";
import TopicPill from "../../components/TopicPill.astro";
import PaperCardCompact from "../../components/PaperCardCompact.astro";
import {
  papers,
  enriched,
  enrichedModel,
  formatSessionDate,
  formatSessionTime,
  formatRating,
  type Paper,
  type Enrichment,
} from "../../lib/data";

export async function getStaticPaths() {
  return papers.map((p) => ({
    params: { id: p.id },
    props: { paper: p },
  }));
}

interface Props {
  paper: Paper;
}

const { paper } = Astro.props;
const e: Enrichment | undefined = enriched[paper.id];
const model = enrichedModel || "Claude Haiku 4.5";

const sessionDate = formatSessionDate(paper);
const sessionTime = formatSessionTime(paper);
const rating = formatRating(paper);

// Related papers: same topic, up to 5.
const related = papers
  .filter((p) => p.id !== paper.id && p.topic_slug === paper.topic_slug)
  .slice(0, 5);

const issueTitle = encodeURIComponent(`[${paper.id}] Something off with "${paper.title}"`);
const issueBody = encodeURIComponent(
  `Paper: ${paper.title}\nOpenReview: ${paper.openreview_url ?? ""}\nPage: ${Astro.url.pathname}\n\nWhat's wrong:\n\n`
);
const issueUrl = `https://github.com/bmtlima/iclr-2026-oral/issues/new?title=${issueTitle}&body=${issueBody}`;
---
<Base title={paper.title} description={paper.abstract.slice(0, 200)}>
  <article>
    <div class="text-xs text-neutral-500 mb-3">
      <a href="/" class="no-underline text-neutral-500 hover:text-amber-400">← All orals</a>
    </div>

    <h1 class="text-2xl md:text-3xl font-semibold leading-tight text-neutral-100">{paper.title}</h1>

    <p class="text-neutral-300 mt-3 leading-relaxed">
      {paper.authors.join(", ")}
    </p>

    <div class="mt-4 flex flex-wrap items-center gap-2 text-sm">
      <TopicPill slug={paper.topic_slug} size="sm" />
      {paper.topic_slug_secondary && (
        <TopicPill slug={paper.topic_slug_secondary} size="sm" />
      )}
      {sessionDate && (
        <span class="text-neutral-400 font-mono text-xs">
          {sessionDate}{sessionTime ? ` · ${sessionTime}` : ""}{paper.room ? ` · ${paper.room}` : ""}
        </span>
      )}
      {paper.match_method === "unmatched" && (
        <span class="text-neutral-500 text-xs italic">(session time not found on iclr.cc)</span>
      )}
      {rating && (
        <span class="text-neutral-400 font-mono text-xs">
          <span class="text-neutral-500">Avg rating:</span> {rating}
        </span>
      )}
    </div>

    <div class="mt-4 flex flex-wrap gap-3 text-sm">
      {paper.openreview_url && (
        <a href={paper.openreview_url} class="no-underline text-amber-400 hover:underline">OpenReview ↗</a>
      )}
      {paper.arxiv_url && (
        <a href={paper.arxiv_url} class="no-underline text-amber-400 hover:underline">arXiv ↗</a>
      )}
      {paper.pdf_url && (
        <a href={paper.pdf_url} class="no-underline text-amber-400 hover:underline">PDF ↗</a>
      )}
      {paper.iclrcc_url && (
        <a href={paper.iclrcc_url} class="no-underline text-amber-400 hover:underline">iclr.cc ↗</a>
      )}
    </div>

    {paper.tldr && (
      <section class="mt-8 p-4 rounded border border-neutral-800 bg-neutral-900/50">
        <div class="text-xs uppercase tracking-wider text-neutral-500 font-mono mb-1">Author-provided TL;DR</div>
        <p class="text-neutral-200">{paper.tldr}</p>
      </section>
    )}

    <section>
      <h2 class="mt-8 text-xs uppercase tracking-wider text-neutral-500 font-mono">Abstract</h2>
      <AbstractBlock text={paper.abstract} />
    </section>

    {e ? (
      <>
        {e.one_sentence_summary && (
          <AutoGeneratedBlock
            heading="One-sentence summary"
            model={model}
            variant="prose"
            text={e.one_sentence_summary}
          />
        )}
        <AutoGeneratedBlock
          heading="Contributions"
          model={model}
          items={e.contributions}
          emptyMessage="No contributions extracted."
        />
        <AutoGeneratedBlock
          heading="Methods used"
          model={model}
          variant="chips"
          items={e.methods_used}
        />
        <AutoGeneratedBlock
          heading="Datasets used"
          model={model}
          variant="chips"
          items={e.datasets_used}
        />
        <AutoGeneratedBlock
          heading="Limitations (author-stated)"
          model={model}
          items={e.limitations}
          verbatim
          emptyMessage="Authors did not state explicit limitations."
        />
        <AutoGeneratedBlock
          heading="Future work (author-stated)"
          model={model}
          items={e.future_work}
          verbatim
          emptyMessage="Authors did not state explicit future directions."
        />
      </>
    ) : (
      <section class="ai-block">
        <div class="ai-block-header">Enrichment pending</div>
        <p class="text-neutral-500 italic">AI-assisted summaries have not been generated for this paper yet.</p>
      </section>
    )}

    {paper.keywords.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xs uppercase tracking-wider text-neutral-500 font-mono mb-2">Author keywords</h2>
        <ul class="flex flex-wrap gap-2 list-none p-0 m-0">
          {paper.keywords.map((k) => (
            <li class="text-xs px-2 py-0.5 rounded bg-neutral-900 border border-neutral-800 text-neutral-400 font-mono">{k}</li>
          ))}
        </ul>
      </section>
    )}

    {related.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xs uppercase tracking-wider text-neutral-500 font-mono mb-2">Related orals</h2>
        <div>
          {related.map((p) => <PaperCardCompact paper={p} showTopic={false} />)}
        </div>
      </section>
    )}

    <section class="mt-10 text-xs text-neutral-500">
      <a href={issueUrl} class="no-underline text-neutral-500 hover:text-amber-400">Something off? Let us know →</a>
    </section>
  </article>
</Base>
