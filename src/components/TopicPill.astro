---
import { topicBySlug } from "../lib/data";

interface Props {
  slug: string;
  size?: "xs" | "sm";
}

const { slug, size = "xs" } = Astro.props;
const topic = topicBySlug.get(slug);
const label = topic?.label ?? (slug === "uncategorized" ? "Uncategorized" : slug);
const cls = size === "sm"
  ? "inline-flex items-center px-2.5 py-1 text-sm rounded-full bg-neutral-800 text-neutral-300 no-underline hover:bg-neutral-700 hover:text-amber-400"
  : "inline-flex items-center px-2 py-0.5 text-xs rounded-full bg-neutral-800 text-neutral-300 no-underline hover:bg-neutral-700 hover:text-amber-400";
---
<a href={`/topic/${slug}/`} class={cls}>{label}</a>
