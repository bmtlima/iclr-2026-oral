---
interface Props {
  heading: string;
  model?: string;
  variant?: "bullets" | "prose" | "chips";
  items?: string[];
  text?: string;
  verbatim?: boolean;      // render bullets as blockquotes ("from the paper")
  emptyMessage?: string;
}

const {
  heading,
  model = "Claude Haiku 4.5",
  variant = "bullets",
  items = [],
  text = "",
  verbatim = false,
  emptyMessage,
} = Astro.props;

const hasContent =
  (variant === "prose" && text.trim().length > 0) ||
  (variant !== "prose" && items.length > 0);
---
{(hasContent || emptyMessage) && (
  <section class="ai-block">
    <div class="ai-block-header flex items-center gap-2">
      <span>{heading}</span>
      <span class="text-neutral-600">·</span>
      <span class="text-neutral-500 normal-case tracking-normal">Auto-generated by {model}</span>
      <a href="/about#labels" class="text-neutral-600 hover:text-amber-400 no-underline">(?)</a>
    </div>
    {hasContent ? (
      variant === "prose" ? (
        <p>{text}</p>
      ) : variant === "chips" ? (
        <ul class="flex flex-wrap gap-2 list-none p-0 m-0">
          {items.map((it) => (
            <li class="text-xs px-2 py-0.5 rounded bg-neutral-900 text-neutral-300 font-mono">{it}</li>
          ))}
        </ul>
      ) : verbatim ? (
        <ul class="space-y-2 list-none p-0 m-0">
          {items.map((it) => (
            <li>
              <blockquote class="border-l-2 border-neutral-800 pl-3 text-neutral-300 italic">
                {it}
              </blockquote>
              <div class="text-[10px] uppercase tracking-wider text-neutral-600 mt-0.5">from the paper</div>
            </li>
          ))}
        </ul>
      ) : (
        <ul class="list-disc pl-5 space-y-1 marker:text-neutral-600">
          {items.map((it) => <li>{it}</li>)}
        </ul>
      )
    ) : (
      <p class="text-neutral-500 italic">{emptyMessage}</p>
    )}
  </section>
)}
